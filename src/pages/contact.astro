---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import LocationMapSection from '../components/LocationMapSection.astro';
import PriceCalculator from '../components/PriceCalculator.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Get a Quote - PV Industries";
const pageDescription = "Get an instant quote for solar panel collection. Calculate your price based on customer type, number of panels, and location.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <PriceCalculator />
    <LocationMapSection />
  </main>
  <Footer />
</Layout>
