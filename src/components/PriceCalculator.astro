  .ac-item:hover,
  .ac-item.highlighted {
    background: rgba(253, 181, 0, 0.1);
    color: var(--color-neutral-100);
  }

  .ac-item.ac-no-match {
    color: var(--color-neutral-400);
    font-style: italic;
  }

  .ac-item.ac-no-match:hover {
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-neutral-300);
  }

