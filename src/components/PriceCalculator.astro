---
import suburbData from '../data/suburbs.json';

const contactEmail = "contact@pvindustries.com.au";

const dropOffLocations = [
  {
    state: "NSW",
    dropOffs: ["Bankstown", "Dubbo", "Gosford", "Newcastle", "Thornleigh", "Woy Woy"]
  },
  {
    state: "VIC",
    dropOffs: ["Derrimut", "East Gippsland"]
  },
  {
    state: "SA",
    dropOffs: ["Mitcham"]
  },
  {
    state: "ACT",
    dropOffs: ["Pickup only"]
  }
];

const socialLinks = [
  { name: "Facebook", url: "https://www.facebook.com/pvindustriesAUS", icon: "facebook" },
  { name: "Instagram", url: "https://www.instagram.com/pv_industries", icon: "instagram" },
  { name: "LinkedIn", url: "https://www.linkedin.com/company/pv-industries/", icon: "linkedin" }
];
---

<section id="contact" class="calculator-section">
  <div class="container">
    <div class="calculator-layout">

      <!-- Calculator Card -->
      <div class="calculator-main">
        <div class="calculator-card">

          <!-- Progress Steps -->
          <div class="calc-progress">
            <div class="progress-step active" data-prog="1">
              <span class="step-dot">1</span>
              <span class="step-label">Customer</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="2">
              <span class="step-dot">2</span>
              <span class="step-label">Panels</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="3">
              <span class="step-dot">3</span>
              <span class="step-label">Location</span>
            </div>
          </div>

          <!-- Steps Wrapper -->
          <div class="calc-steps-wrapper">

            <!-- Step 1: Customer Type -->
            <div class="calc-step active" id="step-1">
              <h3 class="step-title">What type of customer are you?</h3>
              <p class="step-subtitle">Select your customer category to start your quote. Pricing is revealed after you complete the form.</p>
              <div class="type-grid">
                <button class="type-card" data-type="residential" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                      <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                  </div>
                  <span class="type-name">Residential</span>
                  <span class="type-price">Instant quote</span>
                  <span class="type-note">Sydney Metro</span>
                </button>
                <button class="type-card" data-type="commercial" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                      <path d="M9 22v-4h6v4"/>
                      <line x1="8" y1="6" x2="8" y2="6"/><line x1="12" y1="6" x2="12" y2="6"/><line x1="16" y1="6" x2="16" y2="6"/>
                      <line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/>
                      <line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/>
                    </svg>
                  </div>
                  <span class="type-name">Commercial</span>
                  <span class="type-price">Instant quote</span>
                  <span class="type-note">Sydney Metro</span>
                </button>
                <button class="type-card" data-type="government" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2L2 7h20L12 2z"/>
                      <rect x="4" y="10" width="16" height="10"/>
                      <line x1="8" y1="10" x2="8" y2="20"/><line x1="12" y1="10" x2="12" y2="20"/><line x1="16" y1="10" x2="16" y2="20"/>
                      <line x1="2" y1="20" x2="22" y2="20"/>
                    </svg>
                  </div>
                  <span class="type-name">Government</span>
                  <span class="type-price">Custom quote</span>
                  <span class="type-note">Contact us</span>
                </button>
                <button class="type-card" data-type="utility" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="5"/>
                      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                  </div>
                  <span class="type-name">Utility</span>
                  <span class="type-price">Custom quote</span>
                  <span class="type-note">Contact us</span>
                </button>
              </div>
            </div>

            <!-- Step 2: Panel Count -->
            <div class="calc-step" id="step-2">
              <h3 class="step-title">How many panels need collecting?</h3>
              <p class="step-subtitle">Enter the number of solar panels for collection. Your quote will be revealed after location.</p>
              <div class="panel-input-wrapper">
                <div class="panel-input-group">
                  <button class="panel-btn panel-minus" type="button" aria-label="Decrease panel count">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <input type="number" id="panel-count" min="1" max="500" value="10" class="panel-input" />
                  <button class="panel-btn panel-plus" type="button" aria-label="Increase panel count">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
                <span class="panel-label">panels</span>
                <p class="panel-hint" id="panel-hint"></p>
              </div>
              <div class="step-actions">
                <button class="btn-back" data-goto="1" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  Back
                </button>
                <button class="btn-next" id="btn-step2-next" type="button">
                  Continue
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>

            <!-- Step 3: Location -->
            <div class="calc-step" id="step-3">
              <h3 class="step-title">Where are the panels located?</h3>
              <p class="step-subtitle">Start typing your suburb or postcode to check if an instant quote is available.</p>
              <p class="service-note">Instant quotes are currently available for Sydney Metro only. For all other areas, please contact us directly for a tailored quote.</p>
              <div class="location-input-wrapper">
                <div class="location-input-group">
                  <svg class="location-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <input type="text" id="location-input" class="location-input" placeholder="e.g. Parramatta or 2150" autocomplete="off" />
                  <!-- Autocomplete dropdown -->
                  <div class="autocomplete-dropdown" id="autocomplete-dropdown"></div>
                </div>
                <p class="location-hint" id="location-hint"></p>
              </div>
              <div class="step-actions">
                <button class="btn-back" data-goto="2" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  Back
                </button>
                <button class="btn-quote" id="btn-get-quote" type="button">
                  Get Quote
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>

          </div>

          <!-- Quote Result -->
          <div class="calc-result" id="result-quote">
            <div class="result-badge success">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="result-title">Your Collection Quote</h3>
            <p class="result-subtitle" id="result-summary"></p>

            <div class="quote-breakdown">
              <div class="quote-row">
                <span class="quote-label">Gate fee <span class="quote-detail" id="r-gate-detail"></span></span>
                <span class="quote-value" id="r-gate-fee"></span>
              </div>
              <div class="quote-row">
                <span class="quote-label">Transport fee <span class="quote-detail" id="r-transport-detail"></span></span>
                <span class="quote-value" id="r-transport-fee"></span>
              </div>
              <div class="quote-divider"></div>
              <div class="quote-row total">
                <span class="quote-label">Total</span>
                <span class="quote-value" id="r-total"></span>
              </div>
              <p class="quote-gst-note">All prices include GST. Transport includes 15% toll allowance.</p>
            </div>

            <div class="result-actions">
              <a class="btn-book" id="btn-book" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Book Collection
              </a>
              <button class="btn-restart" id="btn-restart-quote" type="button">Get New Quote</button>
            </div>
          </div>

          <!-- Email / Large Job Result -->
          <div class="calc-result" id="result-email">
            <div class="result-badge info">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="result-title">Contact Us Directly</h3>
            <p class="result-message" id="email-reason"></p>
            <p class="result-message">Please email us with your details and we'll provide a tailored quote promptly.</p>

            <div class="result-actions">
              <a class="btn-email" id="btn-email-pvi" href={`mailto:${contactEmail}`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Email PV Industries
              </a>
              <button class="btn-restart" id="btn-restart-email" type="button">Get New Quote</button>
            </div>
          </div>

        </div>
      </div>

      <!-- Sidebar: Contact Info -->
      <div class="calculator-sidebar">
        <div class="sidebar-content">
          <div class="sidebar-header">
            <h2 class="sidebar-title">Get in touch</h2>
          </div>

          <div class="sidebar-blocks">
            <div class="sidebar-block">
              <div class="sidebar-block-header">
                <svg class="sidebar-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <h3 class="sidebar-block-title">Contact us</h3>
              </div>
              <div class="sidebar-block-content">
                <p>Email: <a href={`mailto:${contactEmail}`} class="sidebar-link">{contactEmail}</a></p>
              </div>
            </div>

            <div class="sidebar-block">
              <div class="sidebar-block-content">
                <div class="loc-section">
                  <div class="sidebar-block-header">
                    <svg class="sidebar-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M21 10C21 17 12 23 12 23S3 17 3 10C3 5.02944 7.02944 1 12 1C16.9706 1 21 5.02944 21 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <h3 class="sidebar-block-title">Drop-off locations</h3>
                  </div>
                  {dropOffLocations.map((location) => (
                    <div class="loc-group">
                      <p class="loc-text">{location.state}</p>
                      {location.dropOffs.map((dropOff) => (
                        <p class="loc-subtext">{dropOff}</p>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div class="sidebar-social">
            <h3 class="social-heading">Follow us on</h3>
            <div class="social-icons">
              {socialLinks.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-btn"
                  aria-label={`Follow us on ${social.name}`}
                >
                  {social.icon === 'facebook' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M18 2H15C13.6739 2 12.4021 2.52678 11.4645 3.46447C10.5268 4.40215 10 5.67392 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.73478 14.1054 6.48043 14.2929 6.29289C14.4804 6.10536 14.7348 6 15 6H18V2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                  {social.icon === 'instagram' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
                      <path d="M16 11.37C16.1234 12.2022 15.9813 13.0522 15.5938 13.799C15.2063 14.5458 14.5931 15.1514 13.8416 15.5297C13.0901 15.9079 12.2384 16.0396 11.4078 15.9059C10.5771 15.7723 9.80976 15.3801 9.21484 14.7852C8.61992 14.1902 8.22773 13.4229 8.09407 12.5922C7.9604 11.7615 8.09207 10.9099 8.47033 10.1584C8.84859 9.40685 9.45418 8.79374 10.201 8.40624C10.9478 8.01874 11.7978 7.87658 12.63 8C13.4789 8.12588 14.2649 8.52146 14.8717 9.1283C15.4785 9.73515 15.8741 10.5211 16 11.37Z" stroke="currentColor" stroke-width="2"/>
                      <path d="M17.5 6.5H17.51" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                  {social.icon === 'linkedin' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8V8Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="2"/>
                      <circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="2"/>
                    </svg>
                  )}
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="sidebar-divider"></div>
      </div>

    </div>
  </div>

  <div class="section-bg"></div>
</section>

<script is:inline define:vars={{ SUBURBS: suburbData }}>
(function () {
  /* ───────────────── CONFIG ───────────────── */
  var PVI_LAT = -33.9175;
  var PVI_LNG = 151.0353;
  var MAX_DISTANCE_KM = 60;
  var MAX_PANELS = 90;
  var HOURLY_RATE = 100;
  var TOLL_MULTIPLIER = 1.15;
  var LOADING_MINS_PER_PANEL = 1.5;
  var ROAD_FACTOR = 1.5;
  var AVG_SPEED_KPH = 35;
  var CONTACT_EMAIL = 'contact@pvindustries.com.au';

  var PRICING = {
    residential: { label: 'Residential', priceIncGst: 13.20 },
    commercial:  { label: 'Commercial',  priceIncGst: 8.80 }
  };

  /* ───────────────── STATE ────────────────── */
  var state = {
    step: 1,
    customerType: null,
    panelCount: 10,
    selectedSuburb: null,
    distanceKm: null,
    driveMins: null
  };

  /* ───────────────── DOM REFS ─────────────── */
  var steps       = document.querySelectorAll('.calc-step');
  var progSteps   = document.querySelectorAll('.progress-step');
  var progFills   = document.querySelectorAll('.progress-fill');
  var typeCards   = document.querySelectorAll('.type-card');
  var panelInput  = document.getElementById('panel-count');
  var panelHint   = document.getElementById('panel-hint');
  var panelMinus  = document.querySelector('.panel-minus');
  var panelPlus   = document.querySelector('.panel-plus');
  var btnStep2    = document.getElementById('btn-step2-next');
  var locInput    = document.getElementById('location-input');
  var locHint     = document.getElementById('location-hint');
  var dropdown    = document.getElementById('autocomplete-dropdown');
  var btnQuote    = document.getElementById('btn-get-quote');
  var resultQuote = document.getElementById('result-quote');
  var resultEmail = document.getElementById('result-email');
  var backBtns    = document.querySelectorAll('.btn-back');
  var calcProgress = document.querySelector('.calc-progress');
  var stepsWrapper = document.querySelector('.calc-steps-wrapper');

  /* ───────────────── HELPERS ──────────────── */
  function fmt(n) {
    return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function toRad(deg) { return deg * Math.PI / 180; }

  function haversine(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = toRad(lat2 - lat1);
    var dLng = toRad(lng2 - lng1);
    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLng / 2) * Math.sin(dLng / 2);
    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  function estimateDrive(straightLineKm) {
    var roadKm = straightLineKm * ROAD_FACTOR;
    var mins = (roadKm / AVG_SPEED_KPH) * 60;
    return { roadKm: roadKm, mins: mins };
  }

  function formatDistance(km) {
    return km < 1 ? (km * 1000).toFixed(0) + ' m' : km.toFixed(1) + ' km';
  }

  function formatTime(mins) {
    if (mins < 60) return Math.round(mins) + ' min';
    var h = Math.floor(mins / 60);
    var m = Math.round(mins % 60);
    return h + ' hr' + (m > 0 ? ' ' + m + ' min' : '');
  }

  /* ───────────────── NAVIGATION ──────────── */
  function showStep(n) {
    state.step = n;
    steps.forEach(function (el) {
      el.classList.toggle('active', el.id === 'step-' + n);
    });
    progSteps.forEach(function (el) {
      var s = parseInt(el.getAttribute('data-prog'), 10);
      el.classList.toggle('active', s <= n);
      el.classList.toggle('completed', s < n);
    });
    progFills.forEach(function (el, i) {
      el.classList.toggle('filled', i < n - 1);
    });
    hideResults();
  }

  function hideResults() {
    resultQuote.classList.remove('visible');
    resultEmail.classList.remove('visible');
  }

  function hideWizard() {
    calcProgress.classList.add('hidden');
    stepsWrapper.classList.add('hidden');
  }

  function showWizard() {
    calcProgress.classList.remove('hidden');
    stepsWrapper.classList.remove('hidden');
  }

  function showEmailResult(reason) {
    resultQuote.classList.remove('visible');
    document.getElementById('email-reason').textContent = reason;

    var subject = 'Collection Enquiry';
    var body = 'Hi PV Industries,%0D%0A%0D%0A';
    if (state.customerType) body += 'Customer type: ' + state.customerType + '%0D%0A';
    if (state.panelCount) body += 'Number of panels: ' + state.panelCount + '%0D%0A';
    if (state.selectedSuburb) body += 'Location: ' + state.selectedSuburb.name + ' ' + state.selectedSuburb.postcode + '%0D%0A';
    body += '%0D%0APlease provide a quote for collection.%0D%0A%0D%0AThank you';
    document.getElementById('btn-email-pvi').href =
      'mailto:' + CONTACT_EMAIL + '?subject=' + encodeURIComponent(subject) + '&body=' + body;

    resultEmail.classList.add('visible');
  }

  function showQuoteResult(gateFee, transportFee, total) {
    steps.forEach(function (el) { el.classList.remove('active'); });
    hideWizard();
    resultEmail.classList.remove('visible');
    resultQuote.classList.remove('visible');

    var pricing = PRICING[state.customerType];
    var driveEst = estimateDrive(state.distanceKm);

    document.getElementById('result-summary').textContent =
      pricing.label + ' collection of ' + state.panelCount + ' panel' + (state.panelCount !== 1 ? 's' : '') +
      ' — ' + state.selectedSuburb.name + ' (' + formatDistance(driveEst.roadKm) + ', ~' + formatTime(driveEst.mins) + ' drive)';

    document.getElementById('r-gate-detail').textContent =
      '(' + state.panelCount + ' × ' + fmt(pricing.priceIncGst) + ')';
    document.getElementById('r-gate-fee').textContent = fmt(gateFee);
    document.getElementById('r-transport-detail').textContent =
      '(~' + formatTime(driveEst.mins * 2) + ' round trip + loading)';
    document.getElementById('r-transport-fee').textContent = fmt(transportFee);
    document.getElementById('r-total').textContent = fmt(total);

    var subject = 'Collection Booking — ' + state.panelCount + ' panels — ' + fmt(total);
    var body = 'Hi PV Industries,%0D%0A%0D%0A';
    body += 'I would like to book a solar panel collection.%0D%0A%0D%0A';
    body += 'Customer type: ' + pricing.label + '%0D%0A';
    body += 'Number of panels: ' + state.panelCount + '%0D%0A';
    body += 'Location: ' + state.selectedSuburb.name + ' ' + state.selectedSuburb.postcode + '%0D%0A';
    body += 'Estimated distance: ' + formatDistance(driveEst.roadKm) + '%0D%0A%0D%0A';
    body += 'Quoted price: ' + fmt(total) + '%0D%0A';
    body += '  Gate fee: ' + fmt(gateFee) + '%0D%0A';
    body += '  Transport fee: ' + fmt(transportFee) + '%0D%0A%0D%0A';
    body += 'Please confirm availability and next steps.%0D%0A%0D%0AThank you';
    document.getElementById('btn-book').href =
      'mailto:' + CONTACT_EMAIL + '?subject=' + encodeURIComponent(subject) + '&body=' + body;

    resultQuote.classList.add('visible');
  }

  function resetCalculator() {
    state.customerType = null;
    state.panelCount = 10;
    state.selectedSuburb = null;
    state.distanceKm = null;
    state.driveMins = null;

    panelInput.value = '10';
    locInput.value = '';
    panelHint.textContent = '';
    locHint.textContent = '';
    closeDropdown();

    typeCards.forEach(function (c) { c.classList.remove('selected'); });
    showWizard();
    showStep(1);
  }

  /* ──────────── STEP 1: CUSTOMER TYPE ─────── */
  typeCards.forEach(function (card) {
    card.addEventListener('click', function () {
      var type = this.getAttribute('data-type');
      if (type === 'government' || type === 'utility') {
        state.customerType = type;
        showEmailResult(
          'For ' + type + ' projects, we provide customised pricing tailored to your requirements.'
        );
        return;
      }
      state.customerType = type;
      typeCards.forEach(function (c) { c.classList.remove('selected'); });
      this.classList.add('selected');
      setTimeout(function () { showStep(2); }, 250);
    });
  });

  /* ──────────── STEP 2: PANEL COUNT ────────── */
  function updatePanelHint() {
    var val = parseInt(panelInput.value, 10);
    if (isNaN(val) || val < 1) {
      panelHint.textContent = 'Please enter at least 1 panel.';
      panelHint.className = 'panel-hint error';
    } else if (val > MAX_PANELS) {
      panelHint.textContent = 'For jobs over ' + MAX_PANELS + ' panels, please contact us directly for pricing.';
      panelHint.className = 'panel-hint warning';
    } else {
      panelHint.textContent = 'Your quote will appear after you confirm a Sydney Metro location.';
      panelHint.className = 'panel-hint';
    }
  }

  panelInput.addEventListener('input', updatePanelHint);
  panelMinus.addEventListener('click', function () {
    var val = parseInt(panelInput.value, 10) || 1;
    if (val > 1) { panelInput.value = val - 1; updatePanelHint(); }
  });
  panelPlus.addEventListener('click', function () {
    var val = parseInt(panelInput.value, 10) || 0;
    panelInput.value = val + 1;
    updatePanelHint();
  });

  btnStep2.addEventListener('click', function () {
    var val = parseInt(panelInput.value, 10);
    if (isNaN(val) || val < 1) {
      panelHint.textContent = 'Please enter at least 1 panel.';
      panelHint.className = 'panel-hint error';
      return;
    }
    state.panelCount = val;
    if (val > MAX_PANELS) {
      showEmailResult(
        'For collections of more than ' + MAX_PANELS + ' panels, we provide customised pricing.'
      );
      return;
    }
    updatePanelHint();
    showStep(3);
  });

  /* ─────────── STEP 3: LOCATION AUTOCOMPLETE ─ */
  var acHighlight = -1;

  function searchSuburbs(query) {
    if (!query || query.length < 2) return [];
    var q = query.toLowerCase();
    var results = [];
    for (var i = 0; i < SUBURBS.length; i++) {
      var s = SUBURBS[i];
      if (s.name.toLowerCase().indexOf(q) !== -1 || s.postcode.indexOf(q) !== -1) {
        results.push(s);
      }
      if (results.length >= 8) break;
    }
    return results;
  }

  function renderDropdown(results, query) {
    dropdown.innerHTML = '';
    acHighlight = -1;

    if (results.length === 0) {
      if (query && query.length >= 2) {
        var noMatch = document.createElement('div');
        noMatch.className = 'ac-item ac-no-match';
        noMatch.textContent = 'Instant quotes are available for Sydney Metro only — contact us for other areas';
        noMatch.addEventListener('mousedown', function (e) {
          e.preventDefault();
          showEmailResult(
            "Our quote calculator can't yet provide an estimate for your area. Please contact us directly."
          );
        });
        dropdown.appendChild(noMatch);
        dropdown.classList.add('open');
      } else {
        closeDropdown();
      }
      return;
    }

    results.forEach(function (s, idx) {
      var item = document.createElement('div');
      item.className = 'ac-item';
      item.setAttribute('data-idx', idx);
      item.textContent = s.name + ', ' + s.postcode;
      item.addEventListener('mousedown', function (e) {
        e.preventDefault();
        selectSuburb(s);
      });
      dropdown.appendChild(item);
    });
    dropdown.classList.add('open');
  }

  function closeDropdown() {
    dropdown.classList.remove('open');
    dropdown.innerHTML = '';
    acHighlight = -1;
  }

  function selectSuburb(s) {
    state.selectedSuburb = s;
    locInput.value = s.name + ', ' + s.postcode;
    locHint.textContent = '';
    closeDropdown();

    var straightKm = haversine(s.lat, s.lng, PVI_LAT, PVI_LNG);
    var drive = estimateDrive(straightKm);

    if (drive.roadKm > MAX_DISTANCE_KM) {
      state.distanceKm = straightKm;
      state.driveMins = drive.mins;
      showEmailResult(
        'Your location (' + s.name + ') is approximately ' +
        formatDistance(drive.roadKm) + ' from PV Industries, which is outside our standard collection radius of ' +
        MAX_DISTANCE_KM + ' km. Please get in touch for a custom quote.'
      );
    }
  }

  var noMatchTimer = null;

  locInput.addEventListener('input', function () {
    state.selectedSuburb = null;
    var q = this.value.trim();
    var results = searchSuburbs(q);
    renderDropdown(results, q);

    if (noMatchTimer) clearTimeout(noMatchTimer);

    if (q.length >= 3 && results.length === 0) {
      noMatchTimer = setTimeout(function () {
        closeDropdown();
        showEmailResult(
          'For all enquiries outside of Sydney Metro, please contact us directly via the link below.'
        );
      }, 800);
    }
  });

  locInput.addEventListener('keydown', function (e) {
    var items = dropdown.querySelectorAll('.ac-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      acHighlight = Math.min(acHighlight + 1, items.length - 1);
      items.forEach(function (it, i) { it.classList.toggle('highlighted', i === acHighlight); });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      acHighlight = Math.max(acHighlight - 1, 0);
      items.forEach(function (it, i) { it.classList.toggle('highlighted', i === acHighlight); });
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (acHighlight >= 0 && acHighlight < items.length) {
        var idx = parseInt(items[acHighlight].getAttribute('data-idx'), 10);
        var results = searchSuburbs(locInput.value.trim());
        if (results[idx]) selectSuburb(results[idx]);
      }
    } else if (e.key === 'Escape') {
      closeDropdown();
    }
  });

  locInput.addEventListener('blur', function () {
    setTimeout(closeDropdown, 150);
  });

  /* ──────────── GET QUOTE ────────────────── */
  btnQuote.addEventListener('click', function () {
    var q = locInput.value.trim();
    if (!state.selectedSuburb) {
      if (q.length >= 2 && searchSuburbs(q).length === 0) {
        showEmailResult(
          'For all enquiries outside of Sydney Metro, please contact us directly via the link below.'
        );
        return;
      }
      locHint.textContent = 'Please select a suburb from the dropdown.';
      locHint.className = 'location-hint error';
      return;
    }

    var straightKm = haversine(state.selectedSuburb.lat, state.selectedSuburb.lng, PVI_LAT, PVI_LNG);
    var drive = estimateDrive(straightKm);

    state.distanceKm = straightKm;
    state.driveMins = drive.mins;

    if (drive.roadKm > MAX_DISTANCE_KM) {
      showEmailResult(
        'Your location (' + state.selectedSuburb.name + ') is approximately ' +
        formatDistance(drive.roadKm) + ' from PV Industries, which is outside our standard collection radius of ' +
        MAX_DISTANCE_KM + ' km. Please get in touch for a custom quote.'
      );
      return;
    }

    var pricing = PRICING[state.customerType];
    var gateFee = pricing.priceIncGst * state.panelCount;

    var loadingMins = LOADING_MINS_PER_PANEL * state.panelCount;
    var roundTripMins = 2 * state.driveMins;
    var totalLaborMins = loadingMins + roundTripMins;
    var totalHours = totalLaborMins / 60;
    var transportFee = totalHours * HOURLY_RATE * TOLL_MULTIPLIER;

    var total = gateFee + transportFee;
    showQuoteResult(gateFee, transportFee, total);
  });

  /* ──────────── BACK / RESTART ───────────── */
  backBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var goto = parseInt(this.getAttribute('data-goto'), 10);
      showStep(goto);
    });
  });

  document.getElementById('btn-restart-quote').addEventListener('click', resetCalculator);
  document.getElementById('btn-restart-email').addEventListener('click', resetCalculator);

  /* ──────────── INIT ─────────────────────── */
  showStep(1);
})();
</script>

<style>
  /* ══════════ Section ══════════ */
