    { name: 'Woy Woy', state: 'NSW', lat: -33.5, lng: 151.33, mapUrl: 'https://www.google.com/maps/search/?api=1&query=Woy%20Woy%20NSW' },
    { name: 'Derrimut', state: 'VIC', lat: -37.97, lng: 144.58, mapUrl: 'https://www.google.com/maps/search/?api=1&query=Derrimut%20VIC' },
