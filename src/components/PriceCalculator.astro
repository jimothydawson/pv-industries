    overflow-y: auto;
  }

  .autocomplete-dropdown.open { display: block; }

  .ac-item {
    padding: var(--space-3) var(--space-4);
    color: var(--color-neutral-200);
    cursor: pointer;
    font-size: var(--font-size-sm);
