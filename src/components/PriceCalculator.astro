  }

  .type-name { font-weight: 600; font-size: var(--font-size-base); }
  .type-price { font-size: var(--font-size-sm); color: var(--color-primary); font-weight: 600; }
  .type-note { font-size: var(--font-size-xs); color: var(--color-neutral-500); }

  /* ══════════ Panel Input ══════════ */
  .panel-input-wrapper {
    display: flex;
    flex-direction: column;
