---
const contactEmail = "contact@pvindustries.com.au";

const dropOffLocations = [
  {
    state: "NSW",
    dropOffs: [
      { name: "Bankstown", mapUrl: "https://www.google.com/maps/search/?api=1&query=Bankstown%20NSW" },
      { name: "Dubbo", mapUrl: "https://www.google.com/maps/search/?api=1&query=Dubbo%20NSW" },
      { name: "Gosford", mapUrl: "https://www.google.com/maps/search/?api=1&query=Gosford%20NSW" },
      { name: "Newcastle", mapUrl: "https://www.google.com/maps/search/?api=1&query=Newcastle%20NSW" },
      { name: "Thornleigh", mapUrl: "https://www.google.com/maps/search/?api=1&query=Thornleigh%20NSW" },
      { name: "Woy Woy", mapUrl: "https://www.google.com/maps/search/?api=1&query=Woy%20Woy%20NSW" }
    ]
  },
  {
    state: "VIC",
    dropOffs: [
      { name: "Derrimut", mapUrl: "https://www.google.com/maps/search/?api=1&query=Derrimut%20VIC" },
      { name: "East Gippsland", mapUrl: "https://www.google.com/maps/place/Bairnsdale+Regional+Landfill" }
    ]
  },
  {
    state: "SA",
    dropOffs: [
      { name: "Mitcham", mapUrl: "https://www.google.com/maps/search/?api=1&query=Mitcham%20SA" }
    ]
  },
  {
    state: "ACT",
    dropOffs: [{ name: "Pickup only", mapUrl: null }]
  }
];

const socialLinks = [
  { name: "Facebook", url: "https://www.facebook.com/pvindustriesAUS", icon: "facebook" },
  { name: "Instagram", url: "https://www.instagram.com/pv_industries", icon: "instagram" },
  { name: "LinkedIn", url: "https://www.linkedin.com/company/pv-industries/", icon: "linkedin" }
];
---

<section id="contact" class="calculator-section">
  <div class="container">
    <div class="calculator-layout">

      <!-- Calculator Card -->
      <div class="calculator-main">
        <div class="calculator-intro">
          <h2 class="calculator-intro-title">Instant Quote Calculator</h2>
        </div>

        <div class="calculator-card">

          <!-- Progress Steps -->
          <div class="calc-progress">
            <div class="progress-step active" data-prog="1">
              <span class="step-dot">1</span>
              <span class="step-label">Customer</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="2">
              <span class="step-dot">2</span>
              <span class="step-label">Panels</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="3">
              <span class="step-dot">3</span>
              <span class="step-label">Location</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="4">
              <span class="step-dot">4</span>
              <span class="step-label">Quote</span>
            </div>
            <div class="progress-line"><span class="progress-fill"></span></div>
            <div class="progress-step" data-prog="5">
              <span class="step-dot">5</span>
              <span class="step-label">Details</span>
            </div>
          </div>

          <!-- Steps Wrapper -->
          <div class="calc-steps-wrapper">

            <!-- Step 1: Customer Type -->
            <div class="calc-step active" id="step-1">
              <h3 class="step-title">What type of customer are you?</h3>
              <p class="step-subtitle">Select your customer category to start your quote.</p>
              <div class="type-grid">
                <button class="type-card" data-type="residential" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                      <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                  </div>
                  <span class="type-name">Residential</span>
                  <span class="type-price">Instant quote</span>
                  <span class="type-note">Sydney Metro</span>
                </button>
                <button class="type-card" data-type="commercial" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                      <path d="M9 22v-4h6v4"/>
                      <line x1="8" y1="6" x2="8" y2="6"/><line x1="12" y1="6" x2="12" y2="6"/><line x1="16" y1="6" x2="16" y2="6"/>
                      <line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/>
                      <line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/>
                    </svg>
                  </div>
                  <span class="type-name">Commercial</span>
                  <span class="type-price">Instant quote</span>
                  <span class="type-note">Sydney Metro</span>
                </button>
                <button class="type-card" data-type="government" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2L2 7h20L12 2z"/>
                      <rect x="4" y="10" width="16" height="10"/>
                      <line x1="8" y1="10" x2="8" y2="20"/><line x1="12" y1="10" x2="12" y2="20"/><line x1="16" y1="10" x2="16" y2="20"/>
                      <line x1="2" y1="20" x2="22" y2="20"/>
                    </svg>
                  </div>
                  <span class="type-name">Government</span>
                  <span class="type-price">Custom quote</span>
                  <span class="type-note">Contact us</span>
                </button>
                <button class="type-card" data-type="utility" type="button">
                  <div class="type-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="5"/>
                      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                  </div>
                  <span class="type-name">Utility</span>
                  <span class="type-price">Custom quote</span>
                  <span class="type-note">Contact us</span>
                </button>
              </div>
            </div>

            <!-- Step 2: Panel Count -->
            <div class="calc-step" id="step-2">
              <h3 class="step-title">How many panels need collecting?</h3>
              <p class="step-subtitle">Enter the number of solar panels for collection.</p>
              <div class="panel-input-wrapper">
                <div class="panel-input-group">
                  <button class="panel-btn panel-minus" type="button" aria-label="Decrease panel count">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <input type="number" id="panel-count" min="1" max="500" value="10" class="panel-input" />
                  <button class="panel-btn panel-plus" type="button" aria-label="Increase panel count">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
                <span class="panel-label">panels</span>
                <p class="panel-hint" id="panel-hint"></p>
              </div>
              <div class="step-actions">
                <button class="btn-back" data-goto="1" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  Back
                </button>
                <button class="btn-next" id="btn-step2-next" type="button">
                  Continue
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>

            <!-- Step 3: Location -->
            <div class="calc-step" id="step-3">
              <h3 class="step-title">Where are the panels located?</h3>
              <p class="step-subtitle">Start typing your suburb or postcode to check if an instant quote is available.</p>
              <p class="service-note">Instant quotes are currently available for Sydney Metro only. For all other areas, please contact us directly for a tailored quote.</p>
              <div class="location-input-wrapper">
                <div class="location-input-group">
                  <svg class="location-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <input type="text" id="location-input" class="location-input" placeholder="e.g. Parramatta or 2150" autocomplete="off" />
                  <!-- Autocomplete dropdown -->
                  <div class="autocomplete-dropdown" id="autocomplete-dropdown"></div>
                </div>
                <p class="location-hint" id="location-hint"></p>
              </div>
              <div class="step-actions">
                <button class="btn-back" data-goto="2" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  Back
                </button>
                <button class="btn-quote" id="btn-get-quote" type="button">
                  Get Quote
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>
            <!-- Step 4: Quote Options -->
            <div class="calc-step" id="step-4">
              <h3 class="step-title">Choose your quote option</h3>
              <p class="step-subtitle" id="result-summary"></p>

              <div class="quote-options-grid">
                <article class="quote-option-card quote-option-selectable" id="option-collection" data-option="collection" tabindex="0" role="button" aria-pressed="false">
                  <div class="quote-option-head">
                    <h4 class="quote-option-title">Collection Quote</h4>
                    <span class="quote-option-pill">Pickup</span>
                  </div>
                  <p class="quote-option-summary" id="collection-summary"></p>

                  <div class="quote-breakdown">
                    <div class="quote-row">
                      <span class="quote-label">Gate fee <span class="quote-detail" id="r-gate-detail"></span></span>
                      <span class="quote-value" id="r-gate-fee"></span>
                    </div>
                    <div class="quote-row">
                      <span class="quote-label">Transport fee <span class="quote-detail" id="r-transport-detail"></span></span>
                      <span class="quote-value" id="r-transport-fee"></span>
                    </div>
                    <div class="quote-divider"></div>
                    <div class="quote-row total">
                      <span class="quote-label">Total</span>
                      <span class="quote-value" id="r-total"></span>
                    </div>
                    <p class="quote-gst-note">All prices include GST. Transport includes 15% toll allowance.</p>
                  </div>
                </article>

                <article class="quote-option-card quote-option-card--dropoff quote-option-selectable" id="option-dropoff" data-option="dropoff" tabindex="0" role="button" aria-pressed="false">
                  <div class="quote-option-head">
                    <h4 class="quote-option-title">Bankstown Drop-Off Quote</h4>
                    <span class="quote-option-pill">Drop-Off</span>
                  </div>
                  <p class="quote-option-summary">Drop your panels to Bankstown after invoice payment is received.</p>

                  <div class="quote-breakdown">
                    <div class="quote-row">
                      <span class="quote-label">Gate fee <span class="quote-detail" id="r-dropoff-gate-detail"></span></span>
                      <span class="quote-value" id="r-dropoff-gate-fee"></span>
                    </div>
                    <div class="quote-row">
                      <span class="quote-label">Transport fee</span>
                      <span class="quote-value quote-value--muted">Not required</span>
                    </div>
                    <div class="quote-divider"></div>
                    <div class="quote-row total">
                      <span class="quote-label">Total</span>
                      <span class="quote-value" id="r-dropoff-total"></span>
                    </div>
                    <p class="quote-gst-note">All prices include GST. Invoice and exact drop-off address are issued after payment.</p>
                  </div>
                </article>
              </div>

              <p class="option-selection-note" id="option-selection-note">Select Collection or Bankstown Drop-Off to continue.</p>

              <div class="step-actions">
                <button class="btn-back" data-goto="3" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  Back
                </button>
                <button class="btn-next" id="btn-step4-next" type="button" disabled>
                  Continue
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>

            <!-- Step 5: Booking Request Form -->
            <div class="calc-step" id="step-5">
              <div class="custom-quote-routing hidden" id="custom-quote-routing">
                <h3 class="step-title custom-routing-title">Instant quote is unavailable for your postcode.</h3>
                <h4 class="custom-routing-dropoff" id="nearest-dropoff-heading"></h4>
              </div>
              <h3 class="step-title" id="booking-form-title">Book Collection</h3>
              <p class="step-subtitle" id="booking-form-intro"></p>
              <p class="result-message booking-form-notice hidden" id="booking-form-notice"></p>

              <form class="booking-form" id="booking-request-form" method="POST" action="/" netlify-honeypot="bot-field">
              <input type="hidden" name="form-name" id="booking-form-name" value="collection-quote-request" />
              <p class="spam-screen" aria-hidden="true">
                <label>Leave this field empty: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
              </p>
              <p class="spam-screen" aria-hidden="true">
                <label>Website: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
              </p>
              <input type="hidden" name="requestType" id="booking-request-type" value="Collection" />
              <input type="hidden" name="inquiryReason" id="booking-inquiry-reason" value="" />
              <input type="hidden" name="quotedSuburb" id="booking-quoted-suburb" value="" />
              <input type="hidden" name="quotedDistance" id="booking-quoted-distance" value="" />
              <input type="hidden" name="gateFee" id="booking-gate-fee" value="" />
              <input type="hidden" name="transportFee" id="booking-transport-fee" value="" />
              <input type="hidden" name="quoteTotal" id="booking-quote-total" value="" />
              <input type="hidden" name="subject" id="booking-subject" value="" />

              <div class="booking-form-grid">
                <label class="booking-field">
                  <span class="booking-label" id="booking-name-label">Customer Name</span>
                  <input class="booking-input" type="text" name="customerName" autocomplete="name" required />
                </label>

                <label class="booking-field hidden" id="field-business-name">
                  <span class="booking-label" id="booking-business-label">Business Name</span>
                  <input class="booking-input" type="text" name="businessName" autocomplete="organization" />
                </label>

                <label class="booking-field booking-field--full" id="field-collection-address">
                  <span class="booking-label" id="booking-address-label">Collection Address</span>
                  <div class="booking-location-input-group">
                    <input class="booking-input" id="booking-location-input" type="text" name="collectionAddress" autocomplete="off" required />
                    <div class="autocomplete-dropdown booking-autocomplete-dropdown" id="booking-location-dropdown"></div>
                  </div>
                  <span class="booking-field-hint hidden" id="booking-location-hint">Select a suburb/postcode, or keep your manual entry if the location is not listed.</span>
                </label>

                <label class="booking-field">
                  <span class="booking-label" id="booking-phone-label">Contact Number</span>
                  <input class="booking-input" type="tel" name="contactNumber" autocomplete="tel" required />
                </label>

                <label class="booking-field">
                  <span class="booking-label">Email</span>
                  <input class="booking-input" type="email" name="email" autocomplete="email" required />
                </label>

                <label class="booking-field">
                  <span class="booking-label" id="booking-panel-label">Number of Panels</span>
                  <input class="booking-input booking-input--readonly" id="booking-panel-count" type="text" name="panelCount" readonly />
                </label>

                <label class="booking-field">
                  <span class="booking-label">Customer Type</span>
                  <input class="booking-input booking-input--readonly" id="booking-customer-type" type="text" name="customerType" readonly />
                </label>

                <label class="booking-field hidden" id="field-abn">
                  <span class="booking-label">ABN</span>
                  <input class="booking-input" type="text" name="abn" inputmode="numeric" />
                </label>

                <label class="booking-field booking-field--date hidden" id="field-dropoff-date">
                  <span class="booking-label">Preferred Drop-Off Date</span>
                  <input class="booking-input" type="date" name="preferredDropOffDate" />
                </label>

                <label class="booking-field booking-field--full hidden" id="field-project-details">
                  <span class="booking-label">Project Details</span>
                  <textarea class="booking-input booking-textarea" name="projectDetails" rows="3" placeholder="Tell us where the panels are, approximate quantity, access notes, and timing."></textarea>
                </label>
              </div>

              <p class="booking-form-status hidden" id="booking-form-status" aria-live="polite"></p>

              <div class="step-actions step-actions--form">
                <button class="btn-back" id="btn-back-to-quote-options" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                  <span id="booking-back-label">Back to Pickup / Drop-Off Choice</span>
                </button>
                <button class="btn-next btn-submit" id="btn-submit-booking" type="submit">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  Send Request
                </button>
              </div>
              </form>
            </div>

          </div>

          <!-- Email / Large Job Result -->
          <div class="calc-result" id="result-email">
            <div class="result-badge info">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="result-title">Contact Us Directly</h3>
            <p class="result-message" id="email-reason"></p>
            <p class="result-message">Please email us with your details and we'll provide a tailored quote promptly.</p>

            <div class="result-actions">
              <a class="btn-email" id="btn-email-pvi" href={`mailto:${contactEmail}`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Email PV Industries
              </a>
              <button class="btn-restart" id="btn-restart-email" type="button">Get New Quote</button>
            </div>
          </div>

          <form name="collection-quote-request" data-netlify="true" netlify-honeypot="bot-field" hidden>
            <input type="hidden" name="form-name" value="collection-quote-request" />
            <input type="text" name="bot-field" />
            <input type="text" name="requestType" />
            <input type="text" name="inquiryReason" />
            <input type="text" name="customerName" />
            <input type="text" name="businessName" />
            <input type="text" name="collectionAddress" />
            <input type="text" name="contactNumber" />
            <input type="email" name="email" />
            <input type="text" name="panelCount" />
            <input type="text" name="customerType" />
            <input type="text" name="abn" />
            <input type="text" name="preferredDropOffDate" />
            <textarea name="projectDetails"></textarea>
            <input type="text" name="quotedSuburb" />
            <input type="text" name="quotedDistance" />
            <input type="text" name="gateFee" />
            <input type="text" name="transportFee" />
            <input type="text" name="quoteTotal" />
            <input type="text" name="subject" />
            <input type="text" name="website" />
          </form>

          <form name="bankstown-dropoff-request" data-netlify="true" netlify-honeypot="bot-field" hidden>
            <input type="hidden" name="form-name" value="bankstown-dropoff-request" />
            <input type="text" name="bot-field" />
            <input type="text" name="requestType" />
            <input type="text" name="inquiryReason" />
            <input type="text" name="customerName" />
            <input type="text" name="businessName" />
            <input type="text" name="collectionAddress" />
            <input type="text" name="contactNumber" />
            <input type="email" name="email" />
            <input type="text" name="panelCount" />
            <input type="text" name="customerType" />
            <input type="text" name="abn" />
            <input type="text" name="preferredDropOffDate" />
            <textarea name="projectDetails"></textarea>
            <input type="text" name="quotedSuburb" />
            <input type="text" name="quotedDistance" />
            <input type="text" name="gateFee" />
            <input type="text" name="transportFee" />
            <input type="text" name="quoteTotal" />
            <input type="text" name="subject" />
            <input type="text" name="website" />
          </form>

          <form name="custom-quote-request" data-netlify="true" netlify-honeypot="bot-field" hidden>
            <input type="hidden" name="form-name" value="custom-quote-request" />
            <input type="text" name="bot-field" />
            <input type="text" name="requestType" />
            <input type="text" name="inquiryReason" />
            <input type="text" name="customerName" />
            <input type="text" name="businessName" />
            <input type="text" name="collectionAddress" />
            <input type="text" name="contactNumber" />
            <input type="email" name="email" />
            <input type="text" name="panelCount" />
            <input type="text" name="customerType" />
            <input type="text" name="abn" />
            <input type="text" name="preferredDropOffDate" />
            <textarea name="projectDetails"></textarea>
