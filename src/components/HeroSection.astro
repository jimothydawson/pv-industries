---
const heroData = {
  titlePrefix: "Solar panel recycling & collection",
  titleSuffix: "NSW, VIC, SA and ACT",
  partnerLogos: [
    {
      name: "Sustainability Victoria",
      logo: "/images/Sustainability-Victoria-Logo.png",
      alt: "Sustainability Victoria",
      mobileOrder: 7
    },
    {
      name: "NSW EPA",
      logo: "/images/epa_logo_coupled_fullcolour_v2.png",
      alt: "NSW Environment Protection Authority",
      mobileOrder: 3
    },
    {
      name: "Australian Government DISR",
      logo: "/images/logo_disr.png",
      alt: "Australian Government Department of Industry, Science and Resources",
      mobileOrder: 1
    },
    {
      name: "CSIRO",
      logo: "/images/CSIRO-logo.jpeg",
      alt: "CSIRO",
      mobileOrder: 2
    },
    {
      name: "UTS ISF",
      logo: "/images/UTSISF.png",
      alt: "UTS Institute for Sustainable Futures",
      mobileOrder: 5
    },
    {
      name: "UNSW",
      logo: "/images/UNSW.png",
      alt: "UNSW Sydney",
      mobileOrder: 4
    },
    {
      name: "City of Newcastle",
      logo: "/images/City_of_Newcastle_Horizontal_RGB_cropped-1536x433.jpeg",
      alt: "City of Newcastle",
      mobileOrder: 6
    }
  ],
  ctas: [
    {
      title: "Instant Quote",
      href: "/contact",
      external: false,
      variant: "primary"
    },
    {
      title: "Email Us",
      href: "mailto:contact@pvindustries.com.au",
      external: true,
      variant: "secondary"
    }
  ]
};
---

<section class="hero-section" id="hero" data-hero-section>
  <div class="hero-background" aria-hidden="true">
    <video
      class="hero-background-video"
      data-hero-video
      autoplay
      muted
      playsinline
      preload="auto"
    >
      <source src="/images/Industrial_Background_Video_Generation.mp4" type="video/mp4" />
    </video>
  </div>
  
  <div class="container hero-container">
    <div class="hero-top-layout">
      <div class="hero-text-content">
        <h1 class="hero-title">
          {heroData.titlePrefix}
          <br />
          <span class="hero-title-secondary">{heroData.titleSuffix}</span>
        </h1>
      </div>
    </div>
    <div class="hero-partners-band">
      <div class="hero-partners-band-inner">
        <p class="hero-partners-label">Trusted by federal, state and local governments and leading research institutions</p>
        <div class="hero-partners-grid">
          {heroData.partnerLogos.map((partner) => (
            <div class="hero-partner-logo" aria-label={partner.alt} style={`--mobile-order: ${partner.mobileOrder};`}>
              <img src={partner.logo} alt={partner.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="hero-quote-entry">
      <div class="hero-cta-grid">
        {heroData.ctas.map((cta) => (
          <a
            href={cta.href}
            class:list={["hero-quote-card", cta.variant === "primary" ? "hero-quote-card-primary" : "hero-quote-card-secondary"]}
            target={cta.external ? "_self" : undefined}
          >
            <span class="hero-quote-card-title">{cta.title}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    --site-header-height: 80px;
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #000;
    color: var(--color-neutral-100);
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-section {
      height: calc(100vh - var(--site-header-height));
      min-height: calc(100vh - var(--site-header-height));
    }
  }

  .hero-background {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: auto;
    height: 50%;
    background: #000;
    z-index: 0;
  }

  .hero-background::before {
    content: "";
    position: absolute;
    inset: -100% 0 100% 0;
    background: #000;
  }

  .hero-background::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.3) 100%);
  }

  .hero-background-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    padding: 80px 16px 64px 16px; /* Explicit values for easier debugging */
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 640px) {
    .hero-container {
      padding: 80px 24px 64px 24px;
    }
  }

  @media (min-width: 1024px) {
    .hero-container {
      flex: 1 1 auto;
      min-height: 0;
      padding: 32px 32px 24px 32px;
      justify-content: flex-start;
      gap: var(--space-8);
    }
  }

  .hero-text-content {
    max-width: 100%;
    margin-bottom: var(--space-6);
  }

  @media (max-width: 767px) {
    .hero-text-content {
      max-width: 100%;
    }
  }

  .hero-title {
    font-size: clamp(2.15rem, 3.8vw, 3.15rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 0;
    animation: fadeInUp 0.8s ease-out;
    color: var(--color-neutral-100);
  }

  .hero-title-secondary {
    display: inline-block;
  }

  .hero-top-layout {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .hero-top-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-6);
      align-items: start;
    }

    .hero-text-content {
      margin-bottom: 0;
      padding-top: var(--space-4);
      max-width: 980px;
    }
  }

  .hero-quote-entry {
    width: 100%;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .hero-cta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  @media (min-width: 1024px) {
    .hero-quote-entry {
      align-self: center;
      width: min(100%, 640px);
    }
  }

  .hero-quote-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid transparent;
    background: rgba(0, 0, 0, 0.92);
    color: var(--color-neutral-100);
    text-decoration: none;
    transition: transform var(--transition-normal), border-color var(--transition-normal), background-color var(--transition-normal), box-shadow var(--transition-normal);
    backdrop-filter: blur(10px);
  }

  .hero-quote-card-primary {
    background: var(--color-primary);
    border-color: rgba(253, 181, 0, 0.95);
    color: #000;
  }

  .hero-quote-card-secondary {
    background: rgba(0, 0, 0, 0.92);
    border-color: rgba(255, 255, 255, 0.5);
    color: var(--color-neutral-100);
  }

  .hero-quote-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.24);
  }

  .hero-quote-card-primary:hover {
    border-color: rgba(255, 212, 102, 1);
    background: #e0a000;
  }

  .hero-quote-card-secondary:hover {
    border-color: rgba(255, 255, 255, 0.82);
    background: rgba(12, 12, 12, 0.98);
  }

  .hero-quote-card-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .hero-partners-band {
    margin-top: var(--space-8);
    animation: fadeInUp 0.8s ease-out 0.55s both;
    width: 100%;
  }

  .hero-partners-band-inner {
    width: 100%;
  }

  .hero-partners-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    align-items: center;
    justify-items: center;
  }

  .hero-partner-logo {
    width: 100%;
    max-width: 220px;
    min-height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: rgba(15, 23, 42, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-sizing: border-box;
  }

  .hero-partner-logo img {
    max-width: 100%;
    max-height: 54px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) invert(1) brightness(1.08) opacity(0.82);
  }

  @media (min-width: 1024px) {
    .hero-partners-band {
      margin-top: var(--space-6);
      align-self: center;
      padding-bottom: 0;
    }

    .hero-partners-band-inner {
      width: min(100%, 1160px);
      margin: 0 auto;
      padding: 0 var(--space-2);
    }

    .hero-partners-grid {
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: var(--space-4);
    }
  }

  .hero-partners-label {
    margin: 0 0 var(--space-4) 0;
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    text-align: center;
  }

  /* Responsive adjustments */
  @media (max-width: 767px) {
    .hero-background {
      display: none;
    }

    .hero-container {
      padding: 64px 16px 64px 16px; /* Explicit mobile padding for debugging */
    }

    .hero-quote-entry {
      order: 2;
    }

    .hero-partners-band {
      order: 3;
      display: block;
      margin-top: var(--space-6);
    }

    .hero-cta-grid {
      grid-template-columns: 1fr;
    }

    .hero-partners-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-partner-logo {
      order: var(--mobile-order);
    }
  }
</style>
